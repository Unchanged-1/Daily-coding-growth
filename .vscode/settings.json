{
    // === Markdown 预览同步+主题配置 ===
    "markdown.preview.scrollEditorWithPreview": true,
    "markdown.preview.scrollPreviewWithEditor": true,
    "markdown.preview.theme": "auto", // 预览跟随编辑器主题（解决黑白割裂）

    // === Markdown All in One 核心功能 ===
    "markdown.allInOne.autoIndent": true,
    "markdown.allInOne.tableFormatter.enabled": true,

    // === Paste Image 图片自动归类（核心！图片存img文件夹） ===
    "pasteImage.path": "${currentFileDir}/img",
    //  把这一行删掉或注释掉，问题就解决了
    // "pasteImage.prefix": "./img/",
    "pasteImage.encodePath": "urlEncode",
    // 新增：图片文件名加时间戳，避免重名覆盖
    "pasteImage.fileName": "${imageFileName}-${year}-${month}-${day}-${hour}-${minute}-${second}",
    // 新增：默认图片格式（png兼容性最佳）
    "pasteImage.defaultImageFormat": "png",
    // 新增：Windows路径自动转斜杠，避免\转义问题
    "pasteImage.pathConvertorType": "unix",
    // 新增：统一图片插入格式，简洁易读
    "pasteImage.insertPattern": "![${imageFileName}](${imageFilePath})",

    // === markdownlint 规则（屏蔽烦人警告） ===
    "markdownlint.config": {
        "default": true,
        "MD001": false, // 关闭标题层级跳级检查
        "MD022": false, // 关闭标题空行检查
        "MD033": {      // 允许 br 标签（表格换行不报警）
            "allowed_elements": ["br"]
        },
        "MD004": false,// 新增：允许无序列表同时使用 * 和 - 标记
        "MD060": false, // 关闭表格竖线对齐检查
        "MD012": false, // 关闭连续空行检查
        "MD046": {      // 新增：强制使用围栏式代码块，消除MD046警告
            "style": "fenced"
        }
    },

    // === 编辑器基础优化 ===
    "editor.wordWrap": "on",          // 自动换行，不用横向滚动
    "editor.formatOnSave": true,      // 保存自动格式化Markdown
    "json.schemas": [],               // 关闭markdownlint架构加载警告
    "http.proxyStrictSSL": false,     // 新增：辅助解决架构加载网络问题
    "json.schemaDownload.enable": false,
    "security.workspace.trust.untrustedFiles": "open",
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one" // 默认格式化工具
    },
    "markdown.validate.enabled": true
}