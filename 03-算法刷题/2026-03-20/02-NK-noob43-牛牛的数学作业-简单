/*
 * 题目：牛牛的数学作业
 * 来源：牛客网（noob43）
 * 知识类型：C++基础语法 | 极差/方差计算 | 数组操作 | 循环结构 | 浮点数精度处理 | 数据类型（long long防溢出） | 格式化输出（fixed/setprecision）
 * 题目原文：
 *   描述：牛牛的数学作业由若干张试卷组成，每张试卷上有n个数字。需要计算这些数字的极差（最大值减最小值）和方差（方差=1/n * ∑(a_i - 平均值)²，平均值=1/n * ∑a_i）。
 *   输入描述：
 *     第一行输入整数T（1≦T≦100），表示试卷数量；
 *     接下来2T行，每张试卷对应两行：
 *       第一行输入整数n（1≦n≦10⁵），表示本试卷上数字的个数；
 *       第二行输入n个整数a₁,a₂,…,aₙ，用空格隔开，满足|a_i|≦10⁹。
 *   输出描述：
 *     对于每张试卷，输出一行两个数：第一个为极差（整数），第二个为方差（保留小数点后3位的浮点数），中间用空格隔开。
 *   示例1：
 *     输入：
 *     2
 *     5
 *     5 4 3 2 1
 *     7
 *     333 494 655 991 101 591 941
 *     输出：
 *     4 2.000
 *     890 86075.959
 *   难度：简单，通过率41.42%，时间限制1秒，空间限制256M。
 * 核心要求：
 *   1. 正确计算极差（最大值-最小值）和方差（严格按数学公式）；
 *   2. 处理大数溢出问题（求和必须使用long long类型）；
 *   3. 按格式输出：极差为整数，方差保留小数点后3位；
 *   4. 保证算法效率（O(n)时间复杂度，避免超时）。
 * 解题思路：
 *   1. 读入测试用例数T，循环T次处理每张试卷；
 *   2. 读入每张试卷的n，遍历n个数字，同步完成：存储数字、找最大值/最小值、累加求和；
 *   3. 计算平均值（将总和转为浮点数后除以n，避免整数除法）；
 *   4. 再次遍历数字，计算每个数字与平均值差的平方和；
 *   5. 计算方差（平方和除以n），按格式输出极差和方差。
 */
#include<bits/stdc++.h>
using namespace std;
int main() {
    int T,n,a[100005],jc; // jc：存储极差（建议命名为range，提升可读性）
    double fc;            // fc：存储方差（建议命名为variance，提升可读性）
    cin>>T;
    for(int k=0;k<T;k++){  // 处理T组测试用例
        cin>>n;
        long long sum =0;  // 关键：用long long防溢出（1e9*1e5=1e14超出int范围）
        double sum_t=0;    // sum_t：存储平方和（建议命名为square_sum，提升可读性）
        int min1,max1;     // min1：最小值，max1：最大值

        for(int i=0;i<n;i++){
            cin>>a[i];
            if(i==0){      // 初始化最大值和最小值（避免随机初始值）
                min1 = a[0];
                max1 = a[0];
            }
            if(min1>a[i]) min1 = a[i]; // 同步更新最小值
            if(max1<a[i]) max1 = a[i]; // 同步更新最大值
            sum +=a[i];    // 累加求和，用于计算平均值
        }
        
        double avg = (sum*1.0)/n; // 计算平均值：先转double避免整数除法丢失精度
        for(int i=0;i<n;i++){     // 计算每个数与平均值差的平方和
            sum_t  += (a[i]-avg)*(a[i]-avg);
        }
         
        jc = max1 - min1;  // 计算极差：最大值-最小值
        fc = (sum_t*1.0)/n;// 计算方差：平方和除以n
        
        // 格式化输出：方差保留3位小数
        cout<<jc<<' '<<fixed<<setprecision(3)<<fc<<endl;
    }
    return 0;
}

/*
======= 核心重点 & 易错点 =======
【重点】
1. 数据溢出防护：
   - 总和sum必须用long long类型，n≤1e5且|a_i|≤1e9时sum最大值达1e14，远超int存储范围；
   - 平均值计算需将sum转为double，避免整数除法丢失精度；
2. 计算逻辑：
   - 极差：一次遍历同步找最大值/最小值，减少冗余循环；
   - 方差：先算平均值，再求平方和，最后除以n；
3. 格式化输出：
   - 必须使用fixed+setprecision(3)，保证方差保留3位小数；
4. 效率优化：
   - 单次遍历完成存数+找最值+求和，O(n)复杂度满足时限要求。

【易错点】
1. 数据类型错误：sum用int溢出，或未转double导致平均值计算错误；
2. 格式错误：漏写fixed，方差输出科学计数法导致判错；
3. 初始化失误：min1/max1未初始化，使用随机值导致最值计算错误；
4. 代码规范：变量命名不直观，固定数组存在越界风险。

【思维扩展（面试加分）】
1. 内存优化解法（空间O(1)，可直接复制）：
   // 核心代码（替换原数组逻辑，无数组存储）
   int T;
   cin >> T;
   while (T--) {
       int n;
       cin >> n;
       long long sum = 0, sum_sq = 0; // sum：和，sum_sq：平方和
       int min_val = INT_MAX, max_val = INT_MIN;
       // 一次读入：同步算最值、和、平方和（无需存数组）
       for (int i = 0; i < n; i++) {
           long long x;
           cin >> x;
           min_val = min(min_val, (int)x);
           max_val = max(max_val, (int)x);
           sum += x;
           sum_sq += x * x;
       }
       // 方差公式优化：∑a_i²/n - (∑a_i/n)²（减少浮点数误差）
       double avg = (double)sum / n;
       double variance = (double)sum_sq / n - avg * avg;
       int range = max_val - min_val;
       cout << range << ' ' << fixed << setprecision(3) << variance << endl;
   }
   优势：空间复杂度从O(n)降为O(1)，体现空间优化意识，公式更稳定。
*/

