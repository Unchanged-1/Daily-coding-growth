/*
 * 题目：数组计数维护
 * 来源：牛客网（noob44）
 * 知识类型：C++基础语法 | 数组操作 | 循环结构 | 条件判断 | 变量动态维护
 * 题目原文：
 *   描述：给定正整数n和阈值k以及长度为n的整数序列{a₁,a₂,…,aₙ}。动态维护变量S和cnt（初始均为0），按顺序遍历每个下标i执行：
 *         ∙ 若a_i≥k，则S += a_i；
 *         ∙ 若a_i=0且S≥1，则S -= 1且cnt += 1；
 *         ∙ 否则不操作。最终输出cnt的值。
 *   输入描述：
 *     第一行输入整数T(1≦T≦10⁴)，表示测试用例组数；
 *     每组测试用例：
 *       1. 第一行输入两个整数n,k (1≦n≦50; 1≦k≦100)；
 *       2. 第二行输入n个整数a₁~aₙ (0≦a_i≦100)。
 *   输出描述：
 *     对于每组测试用例，输出一行一个整数，表示最终cnt的值。
 *   示例1：
 *     输入：
 *     3
 *     3 2
 *     2 0 1
 *     4 1
 *     0 0 0 0
 *     5 3
 *     3 0 0 4 0
 *     输出：
 *     1
 *     0
 *     3
 *   难度：简单，通过率54.60%，时间限制1秒，空间限制256M。
 * 核心要求：
 *   1. 严格按题目条件顺序更新S和cnt，逻辑无偏差；
 *   2. 多组测试用例独立计算，避免变量复用污染；
 *   3. 保证时间复杂度O(T*n)，满足1秒时限要求；
 *   4. 处理边界条件：S≥1时才执行0对应的扣减操作。
 * 解题思路：
 *   1. 读入测试用例数T，循环处理每组用例；
 *   2. 每组用例读入n、k，初始化S=0、cnt=0；
 *   3. 遍历n个数字，按条件依次更新S和cnt；
 *   4. 遍历结束后输出当前组的cnt值。
 */
#include <bits/stdc++.h>
using namespace std;

int main() {
    int t,n,k,a[101]; // a[101]：存储序列（n≤50，长度足够）
    cin>>t;
    for(int i=0;i<t;i++){
        cin>>n>>k;
        int s=0,cnt=0; // 关键：每组用例重新初始化，避免数据污染
        for(int j=0;j<n;j++){
            cin>>a[j];
            if(a[j]>=k){ // 条件1：a_i≥k，累加至S
                s = s + a[j];
            }
            if(a[j]==0&&s>=1){ // 条件2：a_i=0且S≥1，扣减S并计数
                s = s-1;
                cnt = cnt + 1;
            }
        }    
        cout<<cnt<<endl;
    }
    return 0;
}

/*
======= 核心重点 & 易错点 =======
【重点】
1. 变量初始化：每组测试用例必须重置S和cnt，避免多组数据互相干扰；
2. 条件顺序：严格先判断a_i≥k，再判断a_i=0且S≥1，与题目逻辑一致；
3. 复杂度：O(T*n)（T≤1e4、n≤50），计算量≤5e5，满足1秒时限；
4. 边界控制：仅当S≥1时，遇到0才执行扣减和计数操作。

【易错点】
1. 变量复用：未在每组用例开始时重置S/cnt，导致结果错误；
2. 条件顺序错误：先判断0的条件再判断≥k，违背题目逻辑；
3. 边界遗漏：未检查S≥1就扣减，导致S出现负数；
4. 数组冗余：定义数组存储序列，实际无需额外空间。

【思维扩展】
1. 空间优化解法（空间O(1)）：
   // 核心代码（去掉数组，边读边处理，节省空间）
   int main() {
       int T;
       cin >> T;
       while (T--) {
           int n, k;
           cin >> n >> k;
           int S = 0, cnt = 0;
           for (int j = 0; j < n; j++) {
               int x; // 临时变量存储当前值，无需数组
               cin >> x;
               if (x >= k) S += x;
               if (x == 0 && S >= 1) { S--; cnt++; }
           }
           cout << cnt << endl;
       }
       return 0;
   }
   优势：空间复杂度从O(n)降为O(1)，体现空间优化意识，符合企业编码习惯。
*/

