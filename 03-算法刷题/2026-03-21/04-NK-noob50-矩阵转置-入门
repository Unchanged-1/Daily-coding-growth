/*
 * 题目：矩阵转置
 * 来源：牛客网（noob50）
 * 知识类型：C++基础语法 | 二维数组操作 | 循环结构 | 矩阵转置逻辑
 * 题目原文：
 *   描述：给定n行m列的矩阵，计算并输出其转置矩阵（行列互换）。
 *   输入描述：
 *     第一行输入两个整数n, m（1≦n,m≦10）；
 *     接下来n行，每行输入m个整数（-1e9≦aᵢⱼ≦1e9），用空格分隔。
 *   输出描述：
 *     输出m行n列的转置矩阵，每个元素后跟一个空格。
 *   示例1：
 *     输入：
 *     2 3
 *     1 2 3
 *     4 5 6
 *     输出：
 *     1 4 
 *     2 5 
 *     3 6 
 *   示例2：
 *     输入：
 *     1 4
 *     7 8 9 10
 *     输出：
 *     7 
 *     8 
 *     9 
 *     10 
 *   难度：入门，通过率42.96%，时间限制1秒，空间限制256M。
 * 核心要求：
 *   1. 准确实现矩阵转置逻辑（原矩阵a[i][j]对应转置矩阵b[j][i]）；
 *   2. 按要求输出m行n列的结果，每个元素后带一个空格；
 *   3. 数组大小适配n,m≤10的范围，避免越界；
 *   4. 处理边界情况（如n=1或m=1的特殊矩阵）。
 * 解题思路：
 *   1. 定义两个二维数组a（原矩阵）、b（转置矩阵），大小11*11适配范围；
 *   2. 读入n和m，遍历原矩阵，将a[i][j]赋值给b[j][i]完成转置；
 *   3. 遍历转置矩阵b，按m行n列的格式输出，每个元素后加空格；
 *   4. 每行输出完成后换行，保证格式正确。
 */
#include <bits/stdc++.h>
using namespace std;
int a[11][11],b[11][11]; // 11*11数组适配n,m≤10的边界
int main() {
    int n,m;
    cin>>n>>m;
    // 读取原矩阵并直接完成转置赋值
    for(int i=0;i<n;i++){
        for(int j=0;j<m;j++){
            cin>>a[i][j];
            b[j][i] = a[i][j]; // 核心：转置逻辑，行列互换
        }
    }
    // 输出转置矩阵
    for(int j=0;j<m;j++){
        for(int i=0;i<n;i++){
            cout<<b[j][i]<<' '; // 每个元素后带一个空格
        }
        cout<<endl; // 每行结束换行
    }
    return 0;
}

/*
======= 核心重点 & 易错点 =======
【重点】
1. 转置逻辑：原矩阵的a[i][j]对应转置矩阵的b[j][i]，是核心公式；
2. 边读边转置：读取原矩阵时直接赋值给转置矩阵，无需二次遍历；
3. 输出格式：严格按m行n列输出，每个元素后带一个空格，行尾换行；
4. 数组索引：使用0起始索引，适配循环逻辑，避免行列数错配。

【易错点】
1. 转置逻辑错误：误将b[i][j] = a[i][j]或b[i][j] = a[j][i]，导致行列未互换；
2. 输出行列颠倒：按n行m列输出，而非m行n列；
3. 格式错误：元素后未加空格，或行尾多输出空行/少换行；
4. 边界处理：n=1或m=1时，未正确适配转置后的行列数；
5. 数组大小：定义的数组维度小于11，导致n/m=10时越界。

【思维扩展】
1. 空间优化解法（空间O(1)，无需额外转置数组）：
   // 核心代码（直接按转置后的行列顺序输出，无需存储转置矩阵）
   int main() {
       int n, m;
       cin >> n >> m;
       int a[11][11];
       // 仅存储原矩阵
       for (int i = 0; i < n; i++) {
           for (int j = 0; j < m; j++) {
               cin >> a[i][j];
           }
       }
       // 按转置逻辑输出：先遍历列，再遍历行
       for (int j = 0; j < m; j++) {
           for (int i = 0; i < n; i++) {
               cout << a[i][j] << ' ';
           }
           cout << endl;
       }
       return 0;
   }
   优势：无需额外的转置数组b，空间复杂度从O(n*m)降为O(n*m)（仅存储原矩阵），逻辑更简洁，减少内存占用。
*/

