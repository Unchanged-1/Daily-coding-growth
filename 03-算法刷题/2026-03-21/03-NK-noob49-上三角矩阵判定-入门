/*
 * 题目：上三角矩阵判定
 * 来源：牛客网（noob49）
 * 知识类型：C++基础语法 | 二维数组操作 | 循环结构 | 布尔变量 | 矩阵判定
 * 题目原文：
 *   描述：判断n阶方阵是否为上三角矩阵（主对角线以下的元素都为0，主对角线为左上角到右下角的连线）。
 *   输入描述：
 *     第一行输入整数n（1≦n≦10）；
 *     接下来n行，每行输入n个整数（-1e9≦aᵢⱼ≦1e9），用空格分隔。
 *   输出描述：
 *     是上三角矩阵输出"YES"，否则输出"NO"。
 *   示例1：
 *     输入：
 *     3
 *     1 2 3
 *     0 4 5
 *     0 0 6
 *     输出：YES
 *   示例2：
 *     输入：
 *     3
 *     1 0 0
 *     0 2 0
 *     1 0 3
 *     输出：NO
 *   难度：入门，通过率42.31%，时间限制1秒，空间限制256M。
 * 核心要求：
 *   1. 准确识别主对角线以下的元素（行号>列号的位置）；
 *   2. 判定所有主对角线以下元素是否全为0；
 *   3. 一旦发现非0元素，可提前终止判定，优化效率；
 *   4. 正确输出"YES"/"NO"，注意大小写和格式。
 * 解题思路：
 *   1. 读入n，通过双层循环读取n阶方阵的所有元素；
 *   2. 初始化布尔变量t为true（默认是上三角矩阵）；
 *   3. 遍历主对角线以下的元素（行i从1到n，列j从1到i-1）；
 *   4. 若发现任意一个元素非0，将t设为false并终止当前行遍历；
 *   5. 根据t的值输出"YES"或"NO"。
 */
#include <bits/stdc++.h>
using namespace std;
int a[15][15]; // 数组大小设为15*15，适配n≤10的范围
int main() {
    int n;
    cin>>n;
    // 读取n阶方阵的所有元素
    for(int i=1;i<=n;i++){
        for(int j=1;j<=n;j++){
            cin>>a[i][j];
        }
    }
    bool t = true; // 标记是否为上三角矩阵，初始为true
    // 仅遍历主对角线以下的元素（行号>列号）
    for(int i=1;i<=n;i++){
        for(int j=1;j<i;j++){
            if(a[i][j]!=0){
                t = false;
                break; // 发现非0元素，终止当前行遍历
            }
        }
    }
    // 根据标记输出结果
    if(t){
        cout<<"YES"<<endl;
    }
    else{
        cout<<"NO"<<endl;
    }
    return 0;
}

/*
======= 核心重点 & 易错点 =======
【重点】
1. 判定范围：仅需检查主对角线以下（i>j）的元素，无需遍历整个矩阵；
2. 提前终止：发现非0元素后break，减少无效遍历，优化效率；
3. 数组范围：15*15的数组大小足够覆盖n≤10的边界；
4. 输出格式：严格输出"YES"/"NO"（大写），且换行，符合题目要求。

【易错点】
1. 判定范围错误：误判主对角线以上（j>i）或包含主对角线（i==j）的元素；
2. 循环边界错误：j的循环范围写成j<i+1或j<=i，导致判定范围偏差；
3. 输出错误：输出小写"yes"/"no"，或遗漏换行；
4. 逻辑遗漏：未初始化布尔变量，或初始值设为false；
5. 提前终止不彻底：仅break内层循环，未直接终止整个判定（n≤10时无性能影响）。

【思维扩展】
1. 效率优化解法（边读边判定，节省遍历时间）：
   // 核心代码（读取元素时直接判定，无需存储完整矩阵）
   int main() {
       int n;
       cin >> n;
       bool is_upper = true;
       for (int i = 1; i <= n; i++) {
           for (int j = 1; j <= n; j++) {
               long long x; // 适配元素值范围-1e9~1e9
               cin >> x;
               // 仅判定主对角线以下的元素
               if (i > j && x != 0) {
                   is_upper = false;
               }
           }
       }
       cout << (is_upper ? "YES" : "NO") << endl;
       return 0;
   }
   优势：无需额外存储矩阵（空间O(1)），边读边判定，减少一次完整的矩阵遍历，逻辑更简洁。
*/

